FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1
ENV MASTERBUILD_HEADLESS=true
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Install system deps for browser-use (Playwright/Chromium)
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget gnupg ca-certificates fonts-liberation \
    libnss3 libatk-bridge2.0-0 libdrm2 libxcomposite1 \
    libxdamage1 libxrandr2 libgbm1 libasound2 libpangocairo-1.0-0 \
    libgtk-3-0 libxss1 && \
    groupadd --gid 10001 appuser && useradd --uid 10001 --gid 10001 --create-home --shell /bin/bash appuser && \
    mkdir -p /app/runtime /ms-playwright && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    python -m playwright install chromium

COPY masterbuild_runtime.py orchestrator.py builder_agent.py agent_context.py livestream_tiktok.py ./
RUN chown -R appuser:appuser /app /ms-playwright

USER appuser

CMD ["python", "orchestrator.py"]
